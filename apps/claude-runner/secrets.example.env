# claude-runner environment — copy to secrets.env (chmod 600).
# Loaded by the systemd unit via EnvironmentFile=.

# Optional shared secret. If set, callers must send `X-Runner-Secret: <value>`
# (or one of the legacy per-handler headers). Empty = no auth (only safe on localhost).
CLAUDE_RUNNER_SECRET=

# Plane API credentials — required for the plane-claude and plane-copilot handlers
PLANE_API_KEY=
# UUIDs of the workflow states the handlers transition issues into on completion / failure
PLANE_DONE_STATE_ID=
PLANE_CANCELLED_STATE_ID=
# Plane user UUIDs (assignment gate — handlers no-op unless assigned to the matching agent)
PLANE_CLAUDE_USER_ID=
PLANE_COPILOT_USER_ID=

# GitHub PAT for the plane-copilot handler (needs `repo` scope so it can create
# issues / branches / PRs across the org)
GH_TOKEN=
