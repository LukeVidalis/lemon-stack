# Place this file at ~/docker/notify/.env on lemon-server (mode 600, never commit it).
# Multi-service projects use .env (not secrets.env) — docker compose v2 auto-loads
# it from ~/docker/<repo>/ at runtime, and deploy.sh passes it with --env-file at build time.

# Postgres
DB_NAME=notify
DB_USER=notify
DB_PASSWORD=changeme_in_production

# Internal API auth — same value as other apps' INTERNAL_SUMMARY_SECRET so they
# can call /api/_internal/notify with X-Internal-Secret.
INTERNAL_SUMMARY_SECRET=changeme_long_random_string

# VAPID — generate once with: dotnet run --project tools/GenVapid (see README)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@{{DOMAIN}}
