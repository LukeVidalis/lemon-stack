services:
  tg-notify:
    build: .
    restart: unless-stopped
    ports:
      - "127.0.0.1:${PORT:-8080}:8080"
    environment:
      TELEGRAM_BOT_TOKEN: ${TELEGRAM_BOT_TOKEN}
      TELEGRAM_CHAT_ID: ${TELEGRAM_CHAT_ID}
      API_SECRET: ${API_SECRET}
    networks:
      default: {}
      lemon-internal:
        aliases:
          - tg-notify
    labels:
      loki.project: tg-notify
      loki.environment: production

networks:
  lemon-internal:
    external: true
