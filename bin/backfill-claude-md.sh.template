#!/usr/bin/env bash
#
# backfill-claude-md.sh
#
# Backfills CLAUDE.md into {{GITHUB_ORG}} repos that don't have one yet.
# For each repo: generates CLAUDE.md, commits to chore/claude-md branch,
# opens a PR, enables auto-merge.
#
# Skips repos that already have CLAUDE.md and repos not in {{GITHUB_ORG}}.
#
# Usage:
#   backfill-claude-md.sh [--dry-run]
#
set -euo pipefail

WORK_DIR="{{USER_HOME}}/actions-runner/_work"
GEN_SCRIPT="{{USER_HOME}}/bin/generate-claude-md.sh"
DRY_RUN=false

[[ "${1:-}" == "--dry-run" ]] && DRY_RUN=true

log() { echo "[backfill] $*"; }

# Repos in runner workspace without CLAUDE.md (skip _* dirs and template)
TARGETS=()
for repo_dir in "$WORK_DIR"/*/; do
    repo=$(basename "$repo_dir")
    [[ "$repo" == _* ]] && continue
    [[ "$repo" == template ]] && continue
    workspace="$repo_dir$repo"
    [[ ! -d "$workspace" ]] && continue
    if [[ ! -f "$workspace/CLAUDE.md" ]]; then
        TARGETS+=("$repo")
    fi
done

if [[ ${#TARGETS[@]} -eq 0 ]]; then
    log "No repos need backfill. All runner workspace repos have CLAUDE.md."
    exit 0
fi

log "Repos to backfill: ${TARGETS[*]}"
[[ "$DRY_RUN" == "true" ]] && log "(dry-run mode — no commits or PRs)"

for repo in "${TARGETS[@]}"; do
    workspace="$WORK_DIR/$repo/$repo"
    log "--- Processing: $repo ---"

    # Generate CLAUDE.md (writes to workspace)
    if [[ "$DRY_RUN" == "true" ]]; then
        log "DRY-RUN: would generate $workspace/CLAUDE.md"
        "$GEN_SCRIPT" "$repo" "$workspace" --stdout 2>/dev/null | head -8
        continue
    fi

    "$GEN_SCRIPT" "$repo" "$workspace" 2>&1
    if [[ ! -f "$workspace/CLAUDE.md" ]]; then
        log "WARNING: generator produced no file for $repo, skipping"
        continue
    fi

    cd "$workspace"

    # Check if there's actually something new to commit
    if git ls-files --error-unmatch CLAUDE.md >/dev/null 2>&1; then
        if git diff --quiet HEAD -- CLAUDE.md; then
            log "CLAUDE.md exists and unchanged for $repo, skipping"
            continue
        fi
    fi

    # Create branch, commit, push
    BRANCH="chore/claude-md"
    git checkout -B "$BRANCH"
    git add CLAUDE.md
    git commit -m "chore: add auto-generated CLAUDE.md [skip ci]"
    git push origin "$BRANCH" --force-with-lease

    # Open PR with auto-merge
    existing_pr=$(gh pr list --repo "{{GITHUB_ORG}}/$repo" --head "$BRANCH" --json number --jq '.[0].number' 2>/dev/null || echo "")
    if [[ -n "$existing_pr" ]]; then
        log "PR #$existing_pr already exists for $repo"
    else
        gh pr create \
            --repo "{{GITHUB_ORG}}/$repo" \
            --head "$BRANCH" \
            --title "chore: add auto-generated CLAUDE.md" \
            --body "Auto-generated by \`generate-claude-md.sh\`. Adds stable deployment facts (URL, stack, ports, secrets keys, auth model) for cold-open context." \
            2>&1
    fi

    # Enable auto-merge
    pr_number=$(gh pr list --repo "{{GITHUB_ORG}}/$repo" --head "$BRANCH" --json number --jq '.[0].number' 2>/dev/null || echo "")
    if [[ -n "$pr_number" ]]; then
        gh pr merge "$pr_number" --repo "{{GITHUB_ORG}}/$repo" --auto --merge 2>/dev/null || \
            log "WARNING: auto-merge failed for $repo PR #$pr_number (branch protection may not require checks)"
        log "PR #$pr_number opened and auto-merge enabled for $repo"
    fi

    # Return to deploy branch
    deploy_branch=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|.*/||' || echo "main")
    git checkout "$deploy_branch" 2>/dev/null || git checkout main 2>/dev/null || true

    log "Done: $repo"
done

log "=== Backfill complete ==="
