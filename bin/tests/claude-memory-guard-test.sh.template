#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SCRIPT_UNDER_TEST="$ROOT_DIR/claude-memory-guard.sh"

if [[ ! -f "$SCRIPT_UNDER_TEST" ]]; then
  echo "missing script under test: $SCRIPT_UNDER_TEST" >&2
  exit 1
fi

# shellcheck source=/dev/null
source "$SCRIPT_UNDER_TEST"

fail() {
  echo "FAIL: $*" >&2
  exit 1
}

assert_eq() {
  local expected="$1"
  local actual="$2"
  local message="$3"
  if [[ "$expected" != "$actual" ]]; then
    fail "$message (expected '$expected', got '$actual')"
  fi
}

assert_contains() {
  local needle="$1"
  local haystack="$2"
  local message="$3"
  if [[ "$haystack" != *"$needle"* ]]; then
    fail "$message (missing '$needle')"
  fi
}

mkfixture() {
  local file="$1"
  shift
  mkdir -p "$(dirname "$file")"
  cat >"$file" <<EOF
$*
EOF
}

test_skips_running_when_pressure_is_normal() {
  local result
  result="$(is_memory_pressure 79 2048)"
  assert_eq "no" "$result" "normal memory should not trigger pressure mode"
}

test_selects_stale_permission_prompt_only_under_pressure() {
  local now_ms=$((200 * 60 * 1000))
  local fixture_dir
  fixture_dir="$(mktemp -d)"

  mkfixture "$fixture_dir/111.json" '{"pid":111,"status":"waiting","waitingFor":"permission prompt","updatedAt":6000000}'
  mapfile -t matches < <(collect_killable_sessions "$fixture_dir" "$now_ms" yes)

  assert_eq "1" "${#matches[@]}" "stale permission prompt session should be selected under pressure"
  assert_contains '"pid":111' "${matches[0]}" "selected session should include the stale waiting PID"
}

test_skips_recent_waiting_sessions() {
  local now_ms=$((40 * 60 * 1000))
  local fixture_dir
  fixture_dir="$(mktemp -d)"

  mkfixture "$fixture_dir/222.json" '{"pid":222,"status":"waiting","waitingFor":"permission prompt","updatedAt":1500000}'
  mapfile -t matches < <(collect_killable_sessions "$fixture_dir" "$now_ms" yes)

  assert_eq "0" "${#matches[@]}" "recent waiting sessions must not be selected"
}

test_includes_idle_sessions_only_after_longer_age() {
  local now_ms=$((300 * 60 * 1000))
  local fixture_dir
  fixture_dir="$(mktemp -d)"

  mkfixture "$fixture_dir/333.json" '{"pid":333,"status":"idle","updatedAt":6000000}'
  mkfixture "$fixture_dir/444.json" '{"pid":444,"status":"idle","updatedAt":13000000}'
  mapfile -t matches < <(collect_killable_sessions "$fixture_dir" "$now_ms" yes)

  assert_eq "1" "${#matches[@]}" "only sufficiently stale idle sessions should be selected"
  assert_contains '"pid":333' "${matches[0]}" "older idle session should be selected"
}

test_formats_tg_notify_with_bearer_auth() {
  local payload
  payload="$(build_notify_curl_args "secret-token" '{"message":"hi"}')"

  assert_contains "Authorization: Bearer secret-token" "$payload" "notify call should use bearer auth"
}

test_skips_non_pressure_collection() {
  local now_ms=$((200 * 60 * 1000))
  local fixture_dir
  fixture_dir="$(mktemp -d)"

  mkfixture "$fixture_dir/111.json" '{"pid":111,"status":"waiting","waitingFor":"permission prompt","updatedAt":6000000}'
  mapfile -t matches < <(collect_killable_sessions "$fixture_dir" "$now_ms" no)

  assert_eq "0" "${#matches[@]}" "collection should be empty when pressure mode is off"
}

test_skips_running_when_pressure_is_normal
test_selects_stale_permission_prompt_only_under_pressure
test_skips_recent_waiting_sessions
test_includes_idle_sessions_only_after_longer_age
test_formats_tg_notify_with_bearer_auth
test_skips_non_pressure_collection

echo "PASS"
