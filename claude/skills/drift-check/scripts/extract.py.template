#!/usr/bin/env python3
"""
Extract structured, verifiable claims from a markdown doc.
Reads stdin, writes JSON list to stdout.

Claim types:
  path     — filesystem path that should exist
  container— docker container name that should be running
  port     — TCP port that should be listening on localhost
  subdomain— *.{{DOMAIN}} hostname that should be routed in Caddy
  command  — CLI command that should be available on PATH
  service  — systemd unit that should exist (active or enabled)
  vault    — markdown file referenced inside the Obsidian vault
  skill    — slash-skill referenced as `/name` that should exist

Each claim: {doc, line, type, value, context}
"""
import json, re, sys, os

doc_path = sys.argv[1] if len(sys.argv) > 1 else "<stdin>"
text = sys.stdin.read()

# Known things — prevents catching every backticked phrase
COMMAND_PREFIXES = (
    "docker", "docker-compose", "docker compose",
    "systemctl", "journalctl", "crontab",
    "caddy", "restic", "ufw", "fail2ban-client",
    "ss", "ip", "ping", "curl", "git", "gh",
    "python3", "node", "npm", "bun",
    "grafana-cli",
)
PATH_PREFIXES = ("~/", "/etc/", "/var/", "/home/", "/usr/", "/opt/", "/srv/")
SUBDOMAIN_RE = re.compile(r'\b([a-z][a-z0-9-]*)\.' + re.escape("{{DOMAIN}}") + r'\b')
PORT_RE = re.compile(r'(?:port\s+|:)([0-9]{2,5})\b', re.IGNORECASE)
PATH_RE = re.compile(r'`([^`\s]+)`')
SKILL_RE = re.compile(r'`/([a-z][a-z0-9-]+)`')
SERVICE_RE = re.compile(r'\b([a-z][a-z0-9-]+)\.service\b')
CONTAINER_RE = re.compile(r'\bcontainer[:\s]+`?([a-z][a-z0-9_-]+)`?', re.IGNORECASE)

# Inline `name` mentions where context implies container.
# NOTE: `caddy` runs as systemd on this server, not docker — excluded.
CONTAINER_NAMED = {
    "obsidian", "authentik", "authentik-server", "authentik-worker",
    "watchtower", "portainer", "n8n", "photoprism",
    "dawarich_app", "pihole", "glances", "loki", "grafana",
    "promtail", "plane-web", "twingate", "cloudflared",
}

# Example/placeholder subdomains used in docs — never expected to exist
EXAMPLE_HOSTS = {"myservice", "myapp", "example", "foo", "bar", "baz",
                 "yourapp", "appname", "service", "myproject",
                 "my-app", "my-project", "my-service", "your-app"}

# Skip whole-file: archived docs, deprecated, etc.
if ".archived" in doc_path or "/archive/" in doc_path:
    print("[]")
    sys.exit(0)

claims = []
seen = set()
in_fence = False

def add(typ, value, line, ctx):
    key = (typ, value)
    if key in seen:
        return
    seen.add(key)
    claims.append({
        "doc": doc_path,
        "line": line,
        "type": typ,
        "value": value,
        "context": ctx[:120],
    })

NEGATION_RE = re.compile(r'\b(no[\s`]|not |there is no |doesn\'t exist|no longer\b)', re.IGNORECASE)

# Explicit allowlist of Claude skill names — avoids false positives from URL routes
# and Telegram bot commands that look like `/word` in backticks.
KNOWN_SKILLS = {
    "server-status", "docker-info", "network-info", "pihole", "security-info",
    "deploy", "new-project", "auth", "logging", "plane", "dashboard",
    "households", "notify", "tg-notify", "server-cmd", "lemon", "drift-check",
    "n8n", "update-config", "keybindings-help", "verify", "code-review",
    "fewer-permission-prompts", "loop", "schedule", "claude-api", "run",
    "init", "review", "security-review", "ship", "projects", "retrofit-auth",
    "docker-compose-ops", "statusline-setup",
}

fence_marker = None  # tracks opening marker of the active fence (``` or ~~~)

for i, raw in enumerate(text.splitlines(), 1):
    # Per-line suppression
    if "drift:ignore" in raw:
        continue
    # Track code-fence state — handle both ``` and ~~~ fences
    stripped = raw.strip()
    if not in_fence:
        if stripped.startswith("```") or stripped.startswith("~~~"):
            fence_marker = stripped[:3]
            in_fence = True
            continue
    else:
        if stripped.startswith(fence_marker):
            in_fence = False
            fence_marker = None
            continue
        continue
    line = raw

    # Subdomains
    for m in SUBDOMAIN_RE.finditer(line):
        host = m.group(0)
        sub = m.group(1)
        # exclude wildcard, email-like, and known examples
        if "*" in host or "@" in line[max(0, m.start()-2):m.start()]:
            continue
        if sub in EXAMPLE_HOSTS:
            continue
        add("subdomain", host, i, line.strip())

    # Skills (slash commands) — only flag known Claude skill names, not URL routes
    for m in SKILL_RE.finditer(line):
        v = m.group(1)
        if v in KNOWN_SKILLS:
            add("skill", v, i, line.strip())

    # Systemd services — skip docker-compose label values like `compose.service`
    if not re.search(r'docker.*compose|compose\.(service|project)', line, re.IGNORECASE):
        for m in SERVICE_RE.finditer(line):
            add("service", m.group(1) + ".service", i, line.strip())

    # Backticked tokens — could be paths, files, commands, container refs
    for m in PATH_RE.finditer(line):
        tok = m.group(1).rstrip(",.;:)")
        # Skip placeholders like ~/docker/<repo>/.env and glob patterns like ~/foo/*
        if "<" in tok or ">" in tok or "*" in tok:
            continue
        # Path — split off docker volume mount syntax (path:path or path:ro)
        if tok.startswith(PATH_PREFIXES):
            if NEGATION_RE.search(line):
                continue
            host_part = tok.split(":")[0]
            add("path", host_part, i, line.strip())
            continue
        # Command
        for pfx in COMMAND_PREFIXES:
            if tok == pfx or tok.startswith(pfx + " "):
                add("command", pfx.split()[0], i, line.strip())
                break
        # Container by known set
        if tok in CONTAINER_NAMED:
            add("container", tok, i, line.strip())

    # Ports — only flag if "port" word is near, to avoid noise
    if re.search(r'\bport\b', line, re.IGNORECASE):
        for m in PORT_RE.finditer(line):
            p = int(m.group(1))
            if 1 <= p <= 65535 and p not in (80, 443, 22, 8080):  # skip universal + container default
                add("port", str(p), i, line.strip())

    # Vault doc references — `name.md` patterns near "vault" or "Obsidian"
    if re.search(r'\b(vault|obsidian|lemon-vault)\b', line, re.IGNORECASE):
        for m in re.finditer(r'`([a-z][a-z0-9-]+\.md)`', line, re.IGNORECASE):
            add("vault", m.group(1), i, line.strip())

print(json.dumps(claims, indent=2))
