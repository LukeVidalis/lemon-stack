#!/usr/bin/env bash
# Pre-commit hook: block commits that contain personal data leaks.
# Runs check-templates.sh against the full tracked file tree.
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

if ! bash scripts/check-templates.sh >/dev/null 2>&1; then
  echo "pre-commit: LEAK DETECTED — personal data found in staged files." >&2
  echo "Run: bash scripts/check-templates.sh  for details." >&2
  exit 1
fi
