# Authentik secrets — rendered by setup.sh into ./secrets.env (mode 600). DO NOT COMMIT.
AUTHENTIK_SECRET_KEY={{AUTHENTIK_SECRET_KEY}}
AUTHENTIK_ERROR_REPORTING__ENABLED=false

# Postgres credentials — match what postgres-shared provisioned for the `authentik` DB.
# setup.sh fills these from `~/docker/postgres-shared/secrets/authentik.pw`.
AUTHENTIK_POSTGRESQL__PASSWORD={{AUTHENTIK_DB_PASSWORD}}

# Email — optional. Without these, password-reset emails won't send.
AUTHENTIK_EMAIL__HOST=
AUTHENTIK_EMAIL__PORT=587
AUTHENTIK_EMAIL__USERNAME=
AUTHENTIK_EMAIL__PASSWORD=
AUTHENTIK_EMAIL__USE_TLS=true
AUTHENTIK_EMAIL__FROM=authentik@{{DOMAIN}}

# Bootstrap admin (only consulted on very first startup with an empty DB)
AUTHENTIK_BOOTSTRAP_PASSWORD={{AUTHENTIK_BOOTSTRAP_PASSWORD}}
AUTHENTIK_BOOTSTRAP_EMAIL={{ADMIN_EMAIL}}
AUTHENTIK_BOOTSTRAP_TOKEN={{AUTHENTIK_BOOTSTRAP_TOKEN}}
