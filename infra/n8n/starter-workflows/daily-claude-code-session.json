{
  "name": "Daily Claude Code Session",
  "description": null,
  "isArchived": false,
  "nodes": [
    {
      "id": "sched-trigger-001",
      "name": "7 AM Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        240,
        300
      ],
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 6 * * *"
            }
          ]
        }
      }
    },
    {
      "id": "set-prompt-001",
      "name": "Set Prompt",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        480,
        300
      ],
      "parameters": {
        "mode": "manual",
        "fields": {
          "values": [
            {
              "name": "prompt",
              "type": "stringValue",
              "value": "Say hi!"
            },
            {
              "name": "work_dir",
              "type": "stringValue",
              "value": "{{USER_HOME}}"
            },
            {
              "name": "label",
              "type": "stringValue",
              "value": "morning-check"
            }
          ]
        }
      }
    },
    {
      "id": "http-runner-001",
      "name": "Trigger Claude Runner",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        720,
        300
      ],
      "parameters": {
        "method": "POST",
        "url": "http://host.docker.internal:9879/run/scheduled",
        "sendHeaders": false,
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ prompt: $json.prompt, work_dir: $json.work_dir, label: $json.label }) }}",
        "options": {
          "timeout": 5000
        }
      }
    }
  ],
