            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Over Threshold?": {
      "main": [
        [
          {
            "node": "Alert: Disk Full",
            "type": "main",
            "index": 0
          }
        ],
        []
      ]
    }
  },
