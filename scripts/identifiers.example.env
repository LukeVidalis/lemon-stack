# identifiers.example.env — template for scripts/identifiers.env (gitignored).
#
# These are the personal values that the leak guard (check-templates.sh) must
# never find in the public tree, and that promote.sh / drift-check.sh replace
# with {{VAR}} placeholders when templatizing live files.
#
# Setup: cp scripts/identifiers.example.env scripts/identifiers.env
# then fill in your real values. CI provides the maintainer's real file via
# the LEAK_GUARD_IDENTIFIERS repo secret; forks without the secret skip the
# leak scan (the structural checks still run).

IDENT_DOMAIN=example.com
IDENT_ADMIN_EMAIL=you@example.com
IDENT_GITHUB_ORG=my-github-org
IDENT_GITHUB_USERNAME=my-github-username
IDENT_TELEGRAM_CHAT_ID=000000000
IDENT_SERVER_IP=192.0.2.1
IDENT_USER_HOME=/home/me
IDENT_PLANE_PROJECT_ID=00000000-0000-0000-0000-000000000000
IDENT_PLANE_API_KEY_FILE_ID=0000000000000
IDENT_PLANE_PROJECT_PREFIX=MYPROJECT
