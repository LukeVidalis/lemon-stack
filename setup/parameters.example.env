# lemon-stack parameters — copy to parameters.env (chmod 600) and edit, OR run setup.sh
# to generate interactively. Any {{VAR}} in a *.template file under infra/, deploy/,
# claude/, or apps/ that matches a key here is substituted at render time.
#
# Lines starting with `#` and blank lines are ignored. KEY=value, no quoting needed,
# values may contain spaces (no escaping).

# ---------- Core (always required) ----------
DOMAIN=example.com
GITHUB_ORG=myorg
GITHUB_USERNAME=mygithubuser
ADMIN_EMAIL=me@example.com
ADMIN_USERNAME=admin
USER_HOME=/home/admin
HOSTNAME=lemon-stack-host
TIMEZONE=UTC

# ---------- Network ----------
# Set to your LAN IP if this is a homelab install (used by Pi-hole, n8n extra_hosts).
# Leave as `0.0.0.0` on a VPS.
SERVER_IP=0.0.0.0

# ---------- Cloudflare Tunnel (mandatory) ----------
# From: Cloudflare dashboard → Zero Trust → Networks → Tunnels → your tunnel → install token
CLOUDFLARE_TUNNEL_TOKEN=

# ---------- Authentik bootstrap ----------
# setup.sh auto-generates these if left blank. If you set them, they take effect
# only on first install — they have no effect once Authentik has a populated DB.
AUTHENTIK_SECRET_KEY=
AUTHENTIK_BOOTSTRAP_PASSWORD=
AUTHENTIK_BOOTSTRAP_TOKEN=
AUTHENTIK_DB_PASSWORD=

# ---------- Optional components (comma-separated, no spaces) ----------
# Core components (caddy, cloudflare, authentik, postgres-shared) always install.
# Choose any subset of: openbao, monitoring, n8n, pihole, claude-runner, obsidian, backup
# backup — restic backups (any backend: S3/R2, sftp, local path) + guided restore.
#          Prompts for repository + password on install; see docs/backup-restore.md.
COMPONENTS=openbao,monitoring,backup

# ---------- tg-notify (optional, only if you ticked apps/tg-notify) ----------
# Create a Telegram bot via @BotFather, then send it any message.
# Get your chat ID: curl "https://api.telegram.org/bot<TOKEN>/getUpdates" | jq '.result[0].message.chat.id'
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---------- Pi-hole (optional) ----------
PIHOLE_WEBPASSWORD=

# ---------- Plane automation (optional, only if you use plane-automation in COMPONENTS) ----------
# Workspace slug as it appears in plane URLs, e.g. https://plane.example.com/<workspace>/
PLANE_WORKSPACE=
# Primary project UUID (Plane → project → settings → general)
PLANE_PROJECT_ID=
# State UUID for "In Progress" — used by claude-runner workflows to mark tickets active
PLANE_IN_PROGRESS_STATE_ID=
# API key — put the actual value in setup/secrets.env, NOT here
# PLANE_API_KEY=...
# Agent user IDs (members.csv → click member → URL contains their UUID)
PLANE_CLAUDE_USER_ID=
PLANE_COPILOT_USER_ID=
# Issue prefix of the primary project, e.g. MYSERVER for tickets like MYSERVER-42
PLANE_PROJECT_PREFIX=
# The <id> in the API-key CSV Plane exports (~/secret-key-<id>.csv) — plane-cli reads the key from that file
PLANE_API_KEY_FILE_ID=
